@page
@model Security_UnderTheHood.Pages.Account.LoginModel
@{
}

<div class="container border" style="padding:20px">
    <form method="post">
        <div class="text-danger" asp-validation-summary="All"></div>
        <div class="row mb-3">
            <div class="col-2">
                <label asp-for="Credential.Username"></label>
            </div>

            <div class="col-5">
                <input type="text" value="" asp-for="Credential.Username" class="form-control" />
                <span class="text-danger" asp-validation-for="Credential.Username"></span>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-2">
                <label asp-for="Credential.Password"></label>
            </div>

            <div class="col-5">
                <input type="password" value="" asp-for="Credential.Password" class="form-control" />
                <span class="text-danger" asp-validation-for="Credential.Password"></span>
            </div>
        </div>

        <div class="row mb-3 form-check">
            <div class="col-2">
                <input type="checkbox" class="form-check-input" asp-for="Credential.RememberMe" />
                <label class="form-check-label" asp-for="Credential.RememberMe"></label>
            </div>
            <div class="col-5">
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-2">
                <input type="submit" name="name" value="Login" class="btn btn-primary" />
            </div>
            <div class="col-5">
            </div>
        </div>
    </form>
</div>
